      "id": "no-pricing",
      "name": "No Pricing (Doc Query)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1540, 560]
    },
    {
      "parameters": {
        "jsCode": "// Build the RAG vector search query\n// Using Code node because n8n's Postgres node strips the <=> operator\n// Use .first() to avoid paired-item tracking errors through Code nodes\nconst embedding = $('Embed Query').first().json.embedding;\nconst vectorStr = '[' + embedding.join(',') + ']';\nreturn {\n  json: {\n    query: `SELECT content, metadata, 1 - (embedding <=> '${vectorStr}'::vector) AS similarity FROM document_chunks ORDER BY embedding <=> '${vectorStr}'::vector LIMIT 5`\n  }\n};"
      },
      "id": "build-rag-query",
      "name": "Build RAG Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, 440]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $json.query }}",
        "options": {}
      },
      "id": "rag-search",
      "name": "RAG Search",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2200, 440],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT role, message FROM chat_sessions WHERE user_id = '{{ $('Webhook').first().json.body.userID || 'anonymous' }}' ORDER BY created_at DESC LIMIT 10",
        "options": {}
      },
      "id": "fetch-history",
      "name": "Fetch Chat History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2420, 440],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Assemble the full LLM payload\n// IMPORTANT: Use .first() everywhere to avoid paired-item tracking errors\nconst webhook = $('Webhook').first().json.body;\nconst ragResults = $('RAG Search').all();\nconst historyResults = $('Fetch Chat History').all();\n\n// Get pricing data safely — only one path executes\nlet pricingRaw = null;\ntry {\n  pricingRaw = $('Set Pricing Data').first().json.pricing_data;\n} catch (e) {\n  try {\n    pricingRaw = $('No Pricing (Doc Query)').first().json.pricing_data;\n  } catch (e2) {\n    pricingRaw = null;\n  }\n}\n\n// Build retrieved context from RAG results\nconst retrieved_context = ragResults\n  .filter(r => r.json.content)\n  .map(r => ({\n    content: r.json.content,\n    metadata: typeof r.json.metadata === 'string' ? JSON.parse(r.json.metadata) : (r.json.metadata || {}),\n    similarity: r.json.similarity || 0\n  }));\n\n// Build chat history (reverse to chronological order)\nconst chat_history = historyResults\n  .filter(h => h.json.role && h.json.message)\n  .map(h => ({ role: h.json.role, content: h.json.message }))\n  .reverse();\n\n// Parse pricing data\nlet pricing_data = null;\ntry {\n  if (pricingRaw && pricingRaw !== 'null') {\n    pricing_data = typeof pricingRaw === 'string' ? JSON.parse(pricingRaw) : pricingRaw;\n  }\n} catch (e) {\n  pricing_data = null;\n}\n\n// System prompt for the Sales Engineer AI\nconst system_prompt = `You are a knowledgeable and friendly Sales Engineer for our software platform. Your role is to help potential customers understand which modules and subscription plans best fit their specific business needs.\n\n## Your Behavior\n1. Listen carefully to what the user describes about their business, team size, and requirements.\n2. Recommend modules that specifically solve the problems they described. Always explain WHY each module fits their needs.\n3. Provide accurate pricing using ONLY the pricing data given to you in the context. Never estimate, calculate, or invent any prices.\n4. Be conversational — respond naturally, as a human sales engineer would.\n5. Ask clarifying questions when requirements are vague.\n\n## Hard Constraints\n- ONLY use pricing numbers that appear in the provided pricing context. If no pricing data is provided, say: \"I'd be happy to get you exact pricing — could you tell me which modules interest you?\"\n- NEVER perform arithmetic on prices. If the context says the total is $375.00, say \"$375.00\".\n- If a user's need doesn't match any module in your context, say so honestly.\n- If pricing requires a custom quote, say: \"For enterprise-level pricing, our sales team can put together a custom quote.\"\n- NEVER make up features, modules, or capabilities not in your context.\n- Do NOT reveal you are an AI or discuss your internal architecture.`;\n\nreturn {\n  json: {\n    user_prompt: webhook.prompt,\n    system_prompt: system_prompt,\n    chat_history: chat_history,\n    retrieved_context: retrieved_context,\n    pricing_data: pricing_data\n  }\n};"
      },
