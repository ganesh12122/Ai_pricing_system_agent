    {
      "parameters": {
        "jsCode": "// Build the semantic cache lookup query\n// Using Code node because n8n's Postgres node strips the <=> operator\nconst embedding = $('Embed Query').first().json.embedding;\nconst vectorStr = '[' + embedding.join(',') + ']';\nreturn {\n  json: {\n    query: `SELECT id, query_text, response_text, 1 - (query_embedding <=> '${vectorStr}'::vector) AS similarity FROM semantic_cache WHERE expires_at > NOW() ORDER BY query_embedding <=> '${vectorStr}'::vector LIMIT 1`\n  }\n};"
      },
      "id": "build-cache-query",
      "name": "Build Cache Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
