      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [3520, 300],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
