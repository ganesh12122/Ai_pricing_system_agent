      },
      "id": "set-llm-response",
      "name": "Set LLM Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [3080, 440]
    },
    {
      "parameters": {
        "jsCode": "// Prepare data for saving chat history and final response\n// Use $input.item.json to read from the direct predecessor — avoids paired-item errors\nconst data = $input.item.json;\nconst userID = (data.userID || 'anonymous').toString().replace(/'/g, \"''\");\nconst userMsg = (data.user_prompt || '').replace(/'/g, \"''\");\nconst assistantMsg = (data.response || '').replace(/'/g, \"''\");\n\nconst saveQuery = `INSERT INTO chat_sessions (user_id, role, message) VALUES ('${userID}', 'user', '${userMsg}'), ('${userID}', 'assistant', '${assistantMsg}')`;\n\nreturn {\n  json: {\n    saveQuery: saveQuery,\n    response: assistantMsg.replace(/''/g, \"'\")\n  }\n};"
      },
      "id": "prepare-save",
      "name": "Prepare Save Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3300, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $json.saveQuery }}",
        "options": {}
      },
