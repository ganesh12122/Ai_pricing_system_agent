      },
      "id": "set-llm-response",
      "name": "Set LLM Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2640, 440]
    },
    {
      "parameters": {
        "jsCode": "// Save user message and assistant response to chat_sessions\nconst webhook = $('Webhook').item.json.body;\nconst userID = webhook.userID || null;\nconst userMsg = webhook.prompt;\n\n// Get response from either cache path or LLM path\nlet assistantMsg;\ntry {\n  assistantMsg = $('Set LLM Response').item.json.response;\n} catch (e) {\n  assistantMsg = $('Use Cached Response').item.json.response;\n}\n\nreturn {\n  json: {\n    userID: userID,\n    userMessage: userMsg,\n    assistantMessage: assistantMsg,\n    response: assistantMsg\n  }\n};"
      },
      "id": "prepare-save",
      "name": "Prepare Save Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2860, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO chat_sessions (user_id, role, message) VALUES ($1, 'user', $2), ($1, 'assistant', $3)",
        "options": {
          "queryParams": "={{ $json.userID }},={{ $json.userMessage }},={{ $json.assistantMessage }}"
        }
      },
      "id": "save-chat",
      "name": "Save Chat History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [3080, 300],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "final-response",
              "name": "response",
              "value": "={{ $('Prepare Save Data').item.json.response }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "final-response",
      "name": "Final Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [3300, 300]
    }
