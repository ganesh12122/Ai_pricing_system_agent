    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT content, metadata, 1 - (embedding <=> $1::vector) AS similarity FROM document_chunks ORDER BY embedding <=> $1::vector LIMIT 5",
        "options": {
          "queryParams": "={{ JSON.stringify($('Embed Query').item.json.data.embedding) }}"
        }
