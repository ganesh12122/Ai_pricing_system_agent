      "id": "rag-search",
      "name": "RAG Search",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1760, 440],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT role, message FROM chat_sessions WHERE user_id = $1 ORDER BY created_at DESC LIMIT 10",
        "options": {
          "queryParams": "={{ $('Webhook').item.json.body.userID || '' }}"
        }
      },
      "id": "fetch-history",
      "name": "Fetch Chat History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1980, 440],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "RAG Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Assemble the full LLM payload\nconst webhook = $('Webhook').item.json.body;\nconst ragResults = $('RAG Search').all();\nconst historyResults = $('Fetch Chat History').all();\nconst pricingRaw = $('Set Pricing Data').item?.json?.pricing_data || $('No Pricing (Doc Query)').item?.json?.pricing_data;\n\n// Build retrieved context\nconst retrieved_context = ragResults.map(r => ({\n  content: r.json.content,\n  metadata: typeof r.json.metadata === 'string' ? JSON.parse(r.json.metadata) : r.json.metadata,\n  similarity: r.json.similarity\n}));\n\n// Build chat history (reverse to chronological order)\nconst chat_history = historyResults\n  .map(h => ({ role: h.json.role, content: h.json.message }))\n  .reverse();\n\n// Parse pricing data\nlet pricing_data = null;\ntry {\n  if (pricingRaw && pricingRaw !== 'null') {\n    pricing_data = typeof pricingRaw === 'string' ? JSON.parse(pricingRaw) : pricingRaw;\n  }\n} catch (e) {\n  pricing_data = null;\n}\n\n// System prompt\nconst system_prompt = `You are a knowledgeable and friendly Sales Engineer for our software platform. Your role is to help potential customers understand which modules and subscription plans best fit their specific business needs.\n\n## Your Behavior\n1. Listen carefully to what the user describes about their business, team size, and requirements.\n2. Recommend modules that specifically solve the problems they described. Always explain WHY each module fits their needs.\n3. Provide accurate pricing using ONLY the pricing data given to you in the context. Never estimate, calculate, or invent any prices.\n4. Be conversational — respond naturally, as a human sales engineer would.\n5. Ask clarifying questions when requirements are vague.\n\n## Hard Constraints\n- ONLY use pricing numbers that appear in the provided pricing context. If no pricing data is provided, say: \"I'd be happy to get you exact pricing — could you tell me which modules interest you?\"\n- NEVER perform arithmetic on prices. If the context says the total is $375.00, say \"$375.00\".\n- If a user's need doesn't match any module in your context, say so honestly.\n- If pricing requires a custom quote, say: \"For enterprise-level pricing, our sales team can put together a custom quote.\"\n- NEVER make up features, modules, or capabilities not in your context.\n- Do NOT reveal you are an AI or discuss your internal architecture.`;\n\nreturn {\n  json: {\n    user_prompt: webhook.prompt,\n    system_prompt: system_prompt,\n    chat_history: chat_history,\n    retrieved_context: retrieved_context,\n    pricing_data: pricing_data\n  }\n};"
      },
