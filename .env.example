# =============================================================================
# RAG Sales Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=rag_chatbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Ollama (local — not containerized) ---
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:latest
EMBEDDING_MODEL=nomic-embed-text

# --- n8n (existing container on aob-network) ---
N8N_HOST=n8n
N8N_PORT=5678
N8N_WEBHOOK_URL=http://n8n:5678/webhook/chat

# --- Services (internal Docker network) ---
CHAT_API_PORT=8000
GATEWAY_ROUTER_HOST=http://gateway_router:8001
EMBEDDING_SERVICE_HOST=http://embedding_service:8002
LLM_SERVICE_HOST=http://llm_service:8003
PRICING_API_HOST=http://pricing_api:8004

# --- LLM Service Config ---
# Options: ollama | vllm | openai
INFERENCE_BACKEND=ollama
# Only needed if INFERENCE_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Semantic Cache ---
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_HOURS=168

# --- Chat History ---
MAX_HISTORY_MESSAGES=10
